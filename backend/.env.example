# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/speaksafe_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=speaksafe_dev
DB_USER=username
DB_PASSWORD=password
DB_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here
HASH_SALT_ROUNDS=12

# Blockchain Configuration
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_TESTNET_RPC_URL=https://rpc-mumbai.maticvigil.com
PRIVATE_KEY=your-wallet-private-key-for-contract-deployment
CONTRACT_ADDRESSES_REPORT_REGISTRY=
CONTRACT_ADDRESSES_DAO_GOVERNANCE=
CONTRACT_ADDRESSES_DONATION_TREASURY=

# IPFS Configuration
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080
IPFS_PROJECT_ID=your-infura-ipfs-project-id
IPFS_PROJECT_SECRET=your-infura-ipfs-secret

# Zero-Knowledge Proofs
ZK_CIRCUIT_PATH=./circuits
ZK_PROVING_KEY_PATH=./keys/proving_key.zkey
ZK_VERIFICATION_KEY_PATH=./keys/verification_key.json

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@speaksafe.org
FROM_NAME=SpeakSafe Platform

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png,mp4,mp3,wav
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=true

# Security
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
HELMET_CSP_DIRECTIVES=default-src 'self'

# Monitoring & Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# External APIs
TRANSPARENCY_INTERNATIONAL_API_KEY=
WORLD_BANK_API_KEY=
BLOCKCHAIN_EXPLORER_API_KEY=

# Development
DEBUG=speaksafe:*
SWAGGER_ENABLED=true
