# SpeakSafe Frontend Environment Variables for Vercel

# The VPS IP and the port we assigned for the SpeakSafe API
REACT_APP_API_URL=http://82.112.255.81:3011/api

# Production network configuration
REACT_APP_BLOCKCHAIN_NETWORK=polygon

# (Optional) IPFS Gateway - will use the one on the VPS
REACT_APP_IPFS_GATEWAY=http://82.112.255.81:8081
